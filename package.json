{
  "name": "davasko-llm-wiki",
  "version": "3.0.0",
  "description": "DavASko LLM Wiki — Hierarchical RAG Knowledge Base with Jina v3 Vector Search",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build-index": "node system/build-index.js",
    "build-index:force": "node system/build-index.js --force",
    "query": "node system/query-wiki.js --query",
    "lint": "node system/scripts/lint-wiki.js",
    "validate": "node system/scripts/validate-links.js",
    "eval-retrieval": "node system/scripts/eval-retrieval.js",
    "check-sources": "node system/scripts/check-sources.js",
    "staleness": "node system/scripts/check-staleness.js",
    "sync-rules": "node system/sync-ai-rules.js",
    "setup-model": "node system/scripts/setup-model.js",
    "pack-deps": "node system/scripts/pack-deps.js"
  },
  "dependencies": {
    "@huggingface/transformers": "file:./system/vendor/huggingface-transformers.tgz",
    "js-yaml": "file:./system/vendor/js-yaml-4.1.0.tgz",
    "argparse": "file:./system/vendor/argparse-2.0.1.tgz"
  }
}
