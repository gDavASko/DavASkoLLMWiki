# ═══════════════════════════════════════════════════════════════════════
# Git LFS — DavASkoLLMWiki v3.x
# ═══════════════════════════════════════════════════════════════════════
# Тяжёлые бинарные артефакты: модели ONNX, упакованные npm-зависимости,
# и векторные шарды хранятся через Git LFS, чтобы не раздувать
# основной git-репозиторий.

# ─── ONNX-модели (Jina v3 и др.) ─────────────────────────────────────
system/models-cache/**/*.onnx filter=lfs diff=lfs merge=lfs -text
system/models-cache/**/*.onnx_data filter=lfs diff=lfs merge=lfs -text
system/models-cache/**/*.bin filter=lfs diff=lfs merge=lfs -text
system/models-cache/**/*.safetensors filter=lfs diff=lfs merge=lfs -text

# ─── Упакованные npm-зависимости (.tgz) ──────────────────────────────
system/vendor/*.tgz filter=lfs diff=lfs merge=lfs -text

# ─── Векторные шарды (JSON с эмбеддингами — могут быть большими) ──────
system/index-shards/*.json filter=lfs diff=lfs merge=lfs -text

# ═══════════════════════════════════════════════════════════════════════
# Нормализация текстов и кодировка (см. system/docs/data-standards.md §1)
#   .md            → UTF-8 с BOM; остальные тексты → UTF-8 без BOM, LF.
# ═══════════════════════════════════════════════════════════════════════
*.md   text eol=lf
*.json text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.ps1  text eol=lf
*.mdc  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Бинарные/LFS-артефакты исключены из текстовой нормализации правилами выше.
